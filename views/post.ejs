<%- include('partials/header'); %>

<article class="max-w-2xl mx-auto">
  <!-- Back navigation -->
  <a href="/" class="group inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 mb-8 transition-colors">
    <span class="group-hover:-translate-x-0.5 transition">←</span> 
    <span>All posts</span>
  </a>

  <!-- Title -->
  <h1 class="font-serif-custom text-5xl sm:text-6xl font-semibold tracking-tighter leading-[1.05] text-balance">
    <%= postTitle %>
  </h1>

  <div class="mt-4 flex items-center gap-3 text-sm text-slate-500 dark:text-slate-400">
    <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
    <span class="font-medium tracking-widest uppercase text-xs">B<span class="opacity-60">LOG</span> S<span class="opacity-60">LOG</span> V<span class="opacity-60">LOG</span></span>
    <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
  </div>

  <!-- Rich content from editor -->
  <div class="prose mt-10 text-[17px] leading-relaxed">
    <%- postBody %>
  </div>

  <div class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800 text-sm text-slate-500 dark:text-slate-400">
    Thanks for reading. This piece was unlocked with a small payment.
  </div>
</article>

<%- include('partials/footer'); %>
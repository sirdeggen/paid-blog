# Ghost Configuration (passed to the container)
# See https://ghost.org/docs/config/ for all options

# Required: The public URL of your blog (used for admin, RSS, emails, etc.)
# For local development:
url=http://localhost:3000

# Environment
NODE_ENV=development

# Optional: Database (defaults to SQLite in development)
# database__client=sqlite3

# Optional: Mail configuration (add when you want newsletters / member invites)
# MAIL__TRANSPORT=SMTP
# MAIL__OPTIONS__SERVICE=Mailgun
# MAIL__OPTIONS__AUTH__USER=...
# MAIL__OPTIONS__AUTH__PASS=...

# Environment for the custom Ghost (Node.js) application

NODE_ENV=development
PORT=3000

# Where Ghost will store its SQLite database, images, themes, etc.
CONTENT_PATH=/app/content

# Ghost configuration (passed through to Ghost's Knex/SQLite layer)
database__client=sqlite3
database__connection__filename=/app/content/data/ghost.db

# Public URL used by Ghost for generating links, RSS, admin URLs, etc.
url=http://localhost:3000
